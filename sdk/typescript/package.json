{
  "name": "revive-sdk",
  "version": "0.2.0",
  "description": "Detect AI-agent runs lost to human blockers, resolve them securely, and resume the exact suspended run.",
  "license": "Apache-2.0",
  "author": "Revive Labs",
  "homepage": "https://revivelabs.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlyingPotato437/revive.git",
    "directory": "sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/FlyingPotato437/revive/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-recovery",
    "dead-run-detection",
    "human-in-the-loop",
    "credential-recovery",
    "idempotency",
    "durable-execution",
    "langgraph",
    "vercel-ai",
    "oauth",
    "token-refresh"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vercel-ai": {
      "types": "./dist/vercel-ai.d.ts",
      "default": "./dist/vercel-ai.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3"
  }
}
