# Required in hosted deployments
REVIVE_SECRET=replace-with-at-least-32-random-bytes
REVIVE_ENCRYPTION_KEY=base64-encoded-32-byte-key
REVIVE_ENCRYPTION_KEYS={"2026-07":"base64-encoded-32-byte-key"}
REVIVE_ACTIVE_ENCRYPTION_KEY_ID=2026-07
REVIVE_PUBLIC_URL=https://revive.example.com

# Microsoft Entra Authorization Code + PKCE
ENTRA_TENANT_ID=your-concrete-tenant-id
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:3000/api/oauth/entra/callback
ENTRA_SCOPES=offline_access User.Read Mail.ReadWrite Mail.Send Calendars.Read Files.Read.All
REVIVE_RECOVERY_ACCOUNT=you@your-tenant.example

# Hosted Postgres and queue worker
DATABASE_URL=postgres://revive:revive@localhost:5432/revive
REVIVE_DATABASE_SSL=disable
REVIVE_DB_POOL_SIZE=5
REVIVE_WORKER_SECRET=replace-with-a-random-worker-secret
REVIVE_HEALTH_SECRET=replace-with-a-separate-health-secret
REVIVE_WORKER_STALE_MS=120000
REVIVE_COMPLETED_JOB_RETENTION_DAYS=14
REVIVE_DEAD_JOB_RETENTION_DAYS=90
REVIVE_CASE_RETENTION_DAYS=365

# Signed outbound recovery webhooks
REVIVE_WEBHOOK_URL=https://example.com/webhooks/revive
REVIVE_WEBHOOK_SECRET=replace-with-a-random-webhook-secret

# Signed runtime resume acknowledgement endpoint
REVIVE_RUNTIME_RESUME_URL=https://runtime.example.com/revive/resume
REVIVE_RUNTIME_RESUME_SECRET=replace-with-a-separate-runtime-secret
REVIVE_RUNTIME_CALLBACK_HOST=127.0.0.1
REVIVE_RUNTIME_CALLBACK_PORT=8788
# Optional live-demo overrides. The demo mints its own API key and otherwise
# sends to the connected Microsoft test mailbox.
REVIVE_API_KEY=rv_live_workspace-key-for-the-demo
REVIVE_DEMO_RECIPIENT=you@your-tenant.example

# Nango authorization
NANGO_SECRET_KEY=
NANGO_BASE_URL=https://api.nango.dev
NANGO_ALLOWED_INTEGRATIONS=microsoft-tenant-specific
NANGO_CERT_INTEGRATION_ID=microsoft-tenant-specific
NANGO_CERT_CONNECTION_ID=

# Auth0 Token Vault token exchange
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Optional hosted console authentication. Both values are required to enable SSO.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sso
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/api/auth/clerk/bridge

# Stripe Billing. Use a recurring live Price for production.
STRIPE_SECRET_KEY=rk_live_restricted_key
STRIPE_PRICE_DEV=price_live_monthly_dev
STRIPE_PRICE_TEAM=price_live_monthly_team
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_endpoint

# --- Production (deployed) ---
# Public origin of the deployed console; recovery links are relative, but
# provider callbacks must use this host:
#   Entra redirect  → $REVIVE_PUBLIC_URL/api/oauth/entra/callback
#   update ENTRA_REDIRECT_URI above accordingly, and the Azure app registration.
REVIVE_PUBLIC_URL=https://console.example.com
# Hosted identity (SSO/MFA/session revocation). Both present → Clerk is on.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Notifications and optional Claude-assisted classification.
RESEND_API_KEY=re_...
REVIVE_NOTIFY_FROM=Revive <recovery@example.com>
REVIVE_NOTIFY_EMAIL=ops@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/replace-me
ANTHROPIC_API_KEY=sk-ant-...
REVIVE_CLAUDE_MODEL=claude-sonnet-4-5-20250929
REVIVE_CLAUDE_TIMEOUT_MS=3500
