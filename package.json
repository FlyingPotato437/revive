{
  "name": "revive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node scripts/migrate.mjs",
    "db:backup": "sh scripts/db-backup.sh",
    "db:restore": "sh scripts/db-restore.sh",
    "security:verify-keys": "node --env-file-if-exists=.env.local --import tsx scripts/rotate-encryption.mts",
    "security:rotate-keys": "node --env-file-if-exists=.env.local --import tsx scripts/rotate-encryption.mts --apply",
    "sdk:build": "npm --prefix sdk/typescript run build",
    "bench:revive": "python3 sidecar/benchmarks/revivebench.py",
    "bench:resilience": "python3 sidecar/benchmarks/resilience_campaign.py --runs 1000",
    "demo:golden": "node --import tsx scripts/golden-run.mts",
    "test:golden": "node --import tsx scripts/golden-run.mts --auto",
    "certify:live": ".venv/bin/python sidecar/benchmarks/live_langgraph_nango.py",
    "demo:killer": "node scripts/killer-demo.mjs",
    "worker": "node scripts/worker.mjs",
    "retention": "node scripts/retention.mjs",
    "migrate": "node scripts/migrate.mjs",
    "test:api": "node --env-file-if-exists=.env.local --import tsx scripts/test-control-plane.mts",
    "test:reconciliation": "node --env-file-if-exists=.env.local --import tsx scripts/test-reconciliation.mts",
    "test:billing": "node --env-file-if-exists=.env.local --import tsx scripts/test-billing.mts",
    "test:auth-boundaries": "node --import tsx scripts/test-auth-boundaries.mts",
    "test:hosted-boundaries": "node --env-file-if-exists=.env.local --import tsx scripts/test-hosted-boundaries.mts",
    "test:nango-integrations": "node --import tsx scripts/test-nango-integrations.mts",
    "test:action-policy": "node --import tsx scripts/test-action-policy.mts",
    "test:outcomes": "node --import tsx scripts/test-outcome-transactions.mts",
    "test:action-requests": "node --import tsx scripts/test-action-requests.mts",
    "test:dead-runs": "node --import tsx scripts/test-dead-runs.mts",
    "test:encryption": "node --import tsx scripts/test-encryption-rotation.mts",
    "test:telemetry": "node --import tsx scripts/test-telemetry.mts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.12",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@nangohq/frontend": "^0.70.9",
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "11.18.2",
    "next": "^15.5.19",
    "postgres": "^3.4.7",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "simple-icons": "^15.22.0"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.4",
    "typescript": "5.7.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
